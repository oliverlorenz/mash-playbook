[Unit]
Description=Spoolman ({{ spoolman_identifier }})
{% for service in spoolman_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in spoolman_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ spoolman_identifier }} 2>/dev/null || true'
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ spoolman_identifier }} 2>/dev/null || true'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ spoolman_identifier }} \
      --log-driver=none \
      --network={{ spoolman_container_network }} \
      {% if spoolman_container_http_host_bind_port %}
      -p {{ spoolman_container_http_host_bind_port }}:{{ spoolman_container_http_port }} \
      {% endif %}
      --env-file={{ spoolman_base_path }}/env \
      --label-file={{ spoolman_base_path }}/labels \
      {% for volume in spoolman_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options else '' }} \
      {% endfor %}
      {% for arg in spoolman_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ spoolman_container_image_self_build_name if spoolman_container_image_self_build else spoolman_container_image }}

{% for network in spoolman_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ spoolman_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ spoolman_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ spoolman_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ spoolman_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ spoolman_identifier }}

[Install]
WantedBy=multi-user.target
